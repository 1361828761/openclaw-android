# NEW API 平台配置
PLATFORM_NAME="NEW API"
PLATFORM_DISPLAY_NAME="NEW API"
PLATFORM_BINARY="newapi"
PLATFORM_DATA_DIR="$HOME/.newapi-termux"
PLATFORM_VERSION_CMD="$HOME/.newapi-termux/bin/newapi-run --version"
PLATFORM_START_CMD="manage-newapi start"
PLATFORM_POST_INSTALL_MSG="Run 'manage-newapi start' to start NEW API."

# 依赖声明
PLATFORM_NEEDS_GLIBC=true
PLATFORM_NEEDS_NODEJS=false
PLATFORM_NEEDS_BUILD_TOOLS=false
PLATFORM_NEEDS_PYTHON=false
PLATFORM_NEEDS_PROOT=false

# 安装方法
PLATFORM_INSTALL_METHOD="github_binary"
PLATFORM_GITHUB_REPO="QuantumNous/new-api"
PLATFORM_DEFAULT_PORT=3000
